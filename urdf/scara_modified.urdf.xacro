<?xml version="1.0"?>
<robot name="scara_robot">

  <link name="world"/> <!--fixing the base link to the global origin here-->
  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0"/>
  </joint>


  <link name="base_link"><!-- Defining base link here -->
    <visual>
      <geometry>
        <cylinder radius="0.5" length="7.5"/>
      </geometry>
      <origin xyz="0 0 3.75"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.5" length="7.5"/>
      </geometry>
      <origin xyz="0 0 3.75"/>
    </collision>
    <inertial>
      <mass value="20.0"/>
      <inertia ixx="30" iyy="30" izz="30"
               ixy="0" ixz="0" iyz="0"/> <!--using some junk values so that gazebo doens't cause issues -->
    </inertial>
  </link>


  <joint name="joint1" type="fixed"> <!-- was revolute-->
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 7.5"/> <!--definig link1 at 1.5m from the  base about z-->
    <axis xyz="0 0 1"/>     <!--defining j1 axis of rotatoin along z axis-->
    <limit lower="-3.14" upper="3.14" effort="100" velocity="1.0"/> <!-- making sure the joint goes from -pi to pi. dummy values for effort and velocity-->
  </joint>

  <!-- Link 1 -->
  <link name="link1">
    <visual>
        <geometry>    <!-- adding a joint cylinder that makes it look connected. It is only visual-->
            <cylinder radius="0.6" length="0.6"/>
        </geometry>
        <origin xyz="0 0 0"/>
    </visual>


    <visual><!--Actual link display -->
      <geometry>
        <cylinder radius="0.25" length="4.0"/>
      </geometry>
      <origin xyz="2 0 0" rpy="0 1.5708 0"/> <!--rotating it to make it horizontal-->
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.25" length="4.0"/>
      </geometry>
      <origin xyz="2 0 0" rpy="0 1.5708 0"/>
    </collision>
    <inertial>
      <mass value="10"/>
      <inertia ixx="30" iyy="30" izz="30"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Joint 2 -->
  <joint name="joint2" type="fixed">  <!-- was revolute-->
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="4 0 0.5"/> <!--0.1 vertical offeset to match the diagram-->
    <axis xyz="0 0 1"/> <!--J2 axis along z axis-->
    <limit lower="-3.14" upper="3.14" effort="100" velocity="1.0"/>
  </joint>




  <!-- Link 2 -->
  <link name="link2">

    <visual>
        <geometry>    <!-- adding a joint cylinder that makes it look connected. It is only visual-->
            <cylinder radius="0.6" length="1.2"/>
        </geometry>
        <origin xyz="0 0 -0.6"/>
    </visual>
    <visual>  <!--housing for the prismatic jooint-->
      <geometry>
        <box size="0.5 0.5 1.5"/>
      </geometry>
      <origin xyz="3 0 0"/> <!--offset to match J3-->
    </visual>

    <visual><!--actual link display -->
      <geometry>
        <cylinder radius="0.25" length="3.0"/>
      </geometry>
      <origin xyz="1.5 0 0" rpy="0 1.5708 0"/> <!--horizontal arm-->
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.25" length="3.0"/>
      </geometry>
      <origin xyz="1.5 0 0" rpy="0 1.5708 0"/>
    </collision>
    <inertial>
      <mass value="10"/>
      <inertia ixx="30" iyy="30" izz="30"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Joint 3 -->
  <joint name="joint3" type="prismatic">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="3 0 0"/>
    <axis xyz="0 0 1"/><!--keeping the z axis aligned but negating range to match diagram and have tool come down-->
    <limit lower="-2.5" upper="0" effort="100000" velocity="5.0"/>
  </joint>


  <!-- Link 3-->
  <link name="link3">

    <visual>
      <geometry>
        <cylinder radius="0.25" length="4.0"/> <!--EE starts at -0.4 Z wrt J3-->
      </geometry>
      <origin xyz="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.25" length="4.0"/>
      </geometry>
      <origin xyz="0 0 0"/>
    </collision>
    <inertial>
      <mass value="10"/>
      <inertia ixx="30" iyy="30" izz="30"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>



  <!-- ros2_control interface -->
  <!-- <ros2_control name="scara_system" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>


   <joint name="joint1">
      <command_interface name="position">
        <param name="min">-3.14</param>
        <param name="max">3.14</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint2">
      <command_interface name="position">
        <param name="min">-3.14</param>
        <param name="max">3.14</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint3">
      <command_interface name="effort">
        <param name="min">-100000.0</param>
        <param name="max">100000.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

  </ros2_control>-->

  <!-- Gazebo ros2_control plugin -->
  <gazebo>
    <plugin name="joint_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <joint_name>joint3</joint_name>
      <update_rate>100</update_rate>
    </plugin>
  </gazebo>

</robot>
