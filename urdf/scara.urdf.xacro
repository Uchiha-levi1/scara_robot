<?xml version="1.0"?>
<robot name="scara_robot">

  <link name="world"/> <!--fixing the base link to the global origin here-->
  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0"/>
  </joint>

  
  <link name="base_link"><!-- Defining base link here -->
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.8"/>
      </geometry>
      <origin xyz="0 0 0.4"/>
    </visual>
    <collision>                          
      <geometry>
        <cylinder radius="0.1" length="0.8"/>
      </geometry>
      <origin xyz="0 0 0.4"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" 
               ixy="0" ixz="0" iyz="0"/> <!--using some junk values so that gazebo doens't cause issues -->
    </inertial>
  </link>
  
    
  <joint name="joint1" type="revolute"> <!-- Joint 1 that connects base to link1 -->
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.8"/> <!--definig link1 at 0.8m from the  base about z-->
    <axis xyz="0 0 1"/>     <!--defining j1 along z axis--> 
    <limit lower="-3.14" upper="3.14" effort="100" velocity="1.0"/> <!-- making sure the joint goes from -pi to pi. dummy values for effort and velocity-->
  </joint>

  <!-- Link 1 -->
  <link name="link1">
    <visual>
        <geometry>    <!-- adding a joint cylinder that makes it look connected. It is only visual-->
            <cylinder radius="0.05" length="0.15"/>
        </geometry>
        <origin xyz="1.3 0 0"/>     
    </visual>
    
    <!-- Arm cylinder -->
    <visual>
      <geometry>
        <cylinder radius="0.05" length="1.2"/>
      </geometry>
      <origin xyz="0.6 0 0" rpy="0 1.5708 0"/>
    </visual>
    
    <collision>
      <geometry>
        <cylinder radius="0.05" length="1.2"/>
      </geometry>
      <origin xyz="0.6 0 0" rpy="0 1.5708 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" 
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>



  <!-- Link 2 -->
  <link name="link2">
  
    <!-- Joint3 cylinder -->
    <visual>
        <geometry>
            <box size="0.1 0.1 0.3"/>
        </geometry>
        <origin xyz="1.3 0 0"/>       
    </visual>  
    
    <!-- Arm cylinder --> 
    <visual>
      <geometry>
        <cylinder radius="0.05" length="1.3"/>
      </geometry>
      <origin xyz="0.65 0 0" rpy="0 1.5708 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="1.3"/>
      </geometry>
      <origin xyz="0.65 0 0" rpy="0 1.5708 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" 
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Joint 2 -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="1.2 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="1.0"/>
  </joint>

  <!-- Link 3-->
  <link name="link3">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="1.3"/>
      </geometry>
      <origin xyz="0 0 -0.25"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.03" length="1.3"/>
      </geometry>
      <origin xyz="0 0 -0.25"/>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" 
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Joint 3 -->
  <joint name="joint3" type="prismatic">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="1.3 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0" upper="3.0" effort="100" velocity="1.0"/>
  </joint>

  <!-- ros2_control interface -->
  <ros2_control name="scara_system" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>

    <joint name="joint1">
      <command_interface name="position">
        <param name="min">-3.14</param>
        <param name="max">3.14</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint2">
      <command_interface name="position">
        <param name="min">-3.14</param>
        <param name="max">3.14</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint3">
      <command_interface name="position">
        <param name="min">0.0</param>
        <param name="max">3.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

  </ros2_control>

  <!-- Gazebo ros2_control plugin -->
  <gazebo>
    <plugin name="gazebo_ros2_control" 
            filename="libgazebo_ros2_control.so">
      <parameters>/home/dkndaie/ros2_ws/install/scara_robot/share/scara_robot/config/scara_controllers.yaml</parameters>
    </plugin>
  </gazebo>

</robot>
