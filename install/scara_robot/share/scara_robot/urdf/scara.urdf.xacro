<?xml version="1.0"?>
<robot name="scara_robot">

  <link name="world"/>
  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0"/>
  </joint>

  <!-- Base Link -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.2"/>
      </geometry>
      <origin xyz="0 0 0.1"/>
    </visual>
    <collision>                          
      <geometry>
        <cylinder radius="0.1" length="0.2"/>
      </geometry>
      <origin xyz="0 0 0.1"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" 
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Link 1 -->
  <link name="link1">
   <!-- Joint cylinder -->
    <visual>
        <geometry>
            <cylinder radius="0.05" length="0.15"/>
        </geometry>
        <origin xyz="1.3 0 0"/>     
    </visual>
    
    <!-- Arm cylinder -->
    <visual>
      <geometry>
        <cylinder radius="0.05" length="1.2"/>
      </geometry>
      <origin xyz="0.6 0 0" rpy="0 1.5708 0"/>
    </visual>
    
    <collision>
      <geometry>
        <cylinder radius="0.05" length="1.2"/>
      </geometry>
      <origin xyz="0.6 0 0" rpy="0 1.5708 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" 
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Joint 1 -->
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.8"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="1.0"/>
  </joint>

  <!-- Link 2 -->
  <link name="link2">
  
    <!-- Joint3 cylinder -->
    <visual>
        <geometry>
            <box size="0.1 0.1 0.3"/>
        </geometry>
        <origin xyz="1.3 0 0"/>       
    </visual>  
    
    <!-- Arm cylinder --> 
    <visual>
      <geometry>
        <cylinder radius="0.05" length="1.3"/>
      </geometry>
      <origin xyz="0.65 0 0" rpy="0 1.5708 0"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="1.3"/>
      </geometry>
      <origin xyz="0.65 0 0" rpy="0 1.5708 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" 
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Joint 2 -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="1.2 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="1.0"/>
  </joint>

  <!-- Link 3-->
  <link name="link3">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="1.3"/>
      </geometry>
      <origin xyz="0 0 -0.25"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.03" length="1.3"/>
      </geometry>
      <origin xyz="0 0 -0.25"/>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" 
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Joint 3 -->
  <joint name="joint3" type="prismatic">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="1.3 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0" upper="3.0" effort="100" velocity="1.0"/>
  </joint>

 <!-- Gazebo ros2_control plugin -->
  <gazebo>
    <plugin name="gazebo_ros2_control" 
            filename="libgazebo_ros2_control.so">
      <parameters>$(find scara_robot)/config/scara_controllers.yaml</parameters>
    </plugin>
  </gazebo>

</robot>
